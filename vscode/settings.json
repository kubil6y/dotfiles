{
    // =========================================================
    // 🚀 #VSCODE CONFIG
    // =========================================================
    "window.titleBarStyle": "custom",
    "window.title": " ",
    "window.commandCenter": false,
    "breadcrumbs.enabled": false,
    "window.zoomLevel": 1,
    "workbench.sideBar.location": "left",
    "workbench.secondarySideBar.defaultVisibility": "visible",
    "workbench.editor.focusRecentEditorAfterClose": true,
    // File tree highlights current file
    "explorer.autoReveal": true,
    // Removes layout control buttons in title bar
    "workbench.layoutControl.enabled": false,
    // Compact tabs
    "window.density.editorTabHeight": "compact",
    "workbench.editor.showIcons": false,
    // Disable startup editor (welcome page etc.)
    "workbench.startupEditor": "none",
    // Restores scroll/cursor position when reopening files (disabled)
    "workbench.editor.restoreViewState": false,
    // Sidebar tree indentation width
    "workbench.tree.indent": 12,
    // Menu bar fully hidden
    "window.menuBarVisibility": "hidden",
    "window.customMenuBarAltFocus": false,
    "window.enableMenuBarMnemonics": false,
    "workbench.editor.highlightModifiedTabs": true,
    // Toggle menu bar cycle command
    "settings.cycle": [
        {
            "id": "toggleMenuBar",
            "values": [
                { "window.menuBarVisibility": "hidden" },
                { "window.menuBarVisibility": "visible" },
            ],
        },
        {
            "id": "toggleFontSize",
            "values": [
                {
                    "editor.fontSize": 14,
                    "editor.suggestFontSize": 14,
                    "terminal.integrated.fontSize": 14,
                },
                {
                    "editor.fontSize": 16,
                    "editor.suggestFontSize": 16,
                    "terminal.integrated.fontSize": 16,
                },
            ],
        },
    ],

    // =========================================================
    // 👀 #VSCODE PEEKING
    // =========================================================
    // Vim-like navigation behavior:
    // • Avoid peek except for references
    // • Keep jump history predictable
    // • Preserve stable split/editor positioning
    "editor.stablePeek": false,
    "editor.peekWidgetDefaultFocus": "tree",
    "workbench.editor.enablePreview": false,
    // Prevents preview editors from locking when you start editing
    "workbench.editor.enablePreviewFromQuickOpen": true,
    // Open definition inside editor instead of peek window (closer to Vim gd)
    "editor.gotoLocation.multipleDefinitions": "goto",
    // When multiple results exist, stay in same tab instead of spawning new ones
    "editor.gotoLocation.alternativeDefinitionCommand": "editor.action.goToReferences",
    // Allows Ctrl+o / Ctrl+i jump stack to behave correctly
    "workbench.editor.navigationScope": "editorGroup",
    // Keeps editors from moving around when opening files
    "workbench.editor.openPositioning": "right",
    // Make definition navigation respect splits
    "editor.gotoLocation.multipleDeclarations": "goto",
    "editor.gotoLocation.multipleImplementations": "goto",
    "editor.gotoLocation.multipleTypeDefinitions": "goto",
    "editor.gotoLocation.multipleReferences": "peek",

    // =========================================================
    // 🎭 #EDITOR VISUAL BEHAVIOR
    // =========================================================
    // Removes gutter width
    "editor.glyphMargin": false,
    // No active line highlight (cursor position used instead)
    "editor.renderLineHighlight": "none",
    "editor.lineNumbers": "relative",
    // Hide scrollbar entirely
    "editor.scrollbar.vertical": "hidden",
    "editor.scrollbar.verticalScrollbarSize": 0,
    // Disable indentation guides
    "editor.guides.indentation": false,
    "editor.renderWhitespace": "none",
    // Only highlights bracket near cursor
    "editor.matchBrackets": "near",
    // Disable rainbow brackets
    "editor.bracketPairColorization.enabled": false,
    // Disable sticky scroll header
    "editor.stickyScroll.enabled": false,
    "editor.stickyScroll.maxLineCount": 1,
    // Disable symbol occurrences highlighting
    "editor.occurrencesHighlight": "off",
    // Disable semantic highlighting (use theme TextMate rules only)
    "editor.semanticHighlighting.enabled": false,
    "workbench.iconTheme": "material-icon-theme",
    // Vim style ruler
    // "editor.rulers": [{ "column": 90, "color": "#FFC79920" }],

    // =========================================================
    // 🎮 #EDITOR INPUT / BEHAVIOR
    // =========================================================
    "editor.wordWrap": "on",
    "editor.suggestSelection": "first",
    // Prevent accepting suggestions when typing punctuation
    "editor.acceptSuggestionOnCommitCharacter": false,
    // Disable inline AI suggestions
    "editor.inlineSuggest.enabled": false,
    // Disable auto closing
    "editor.autoClosingBrackets": "never",
    "editor.autoClosingQuotes": "never",
    // Hide cursor in overview ruler
    "editor.hideCursorInOverviewRuler": true,
    // Disable CodeLens (reference counters etc.)
    "editor.codeLens": false,
    // Disable quick fix lightbulb
    "editor.lightbulb.enabled": "off",
    "editor.renderFinalNewline": "off",

    // =========================================================
    // 🖱️ #CURSOR
    // =========================================================
    "editor.cursorStyle": "block",
    "editor.cursorBlinking": "solid",
    // Disable cursor glide animation
    "editor.cursorSmoothCaretAnimation": "off",
    "editor.smoothScrolling": false,

    // =========================================================
    // 📜 #FONT
    // =========================================================
    "editor.fontFamily": "MonoLisa",
    "editor.fontSize": 16,
    "editor.suggestFontSize": 16,
    "terminal.integrated.fontSize": 16,
    "editor.fontVariations": false,
    "editor.fontLigatures": "'zero', 'ss03' on,'ss07' on,'ss13' on,'ss14' on,'ss17' on,'ss18' on",
    // "editor.fontFamily": "Berkeley Mono Variable",
    // "editor.fontSize": 17,
    // "editor.suggestFontSize": 17,
    // "terminal.integrated.fontSize": 17,

    // =========================================================
    // 📂 #FILE / SEARCH / WORKSPACE
    // =========================================================
    // Prevent undo history from persisting across sessions
    "files.restoreUndoStack": false,
    "files.associations": { "*.html": "html" },
    "files.exclude": {
        "**/[Vv]endor/**": true,
        ".godot/": true,
        "**/*.meta": true,
        "**/*.o": true,
        "**/obj": true,
    },
    "search.exclude": {
        "**/*.anim": true,
    },
    // Disable workspace trust prompts
    "security.workspace.trust.enabled": false,

    // =========================================================
    // 📟 #TERMINAL
    // =========================================================
    "terminal.integrated.defaultProfile.linux": "zsh",
    // Prevents VSCode from restoring terminal processes
    "terminal.integrated.persistentSessionReviveProcess": "never",
    "terminal.integrated.inheritEnv": true,

    // =========================================================
    // ⚙️ #LSP
    // =========================================================
    "go.toolsManagement.autoUpdate": true,
    // Unity compatibility (modern .NET OmniSharp breaks Unity sometimes)
    "omnisharp.useModernNet": false,
    "omnisharp.monoPath": "/usr/bin/mono",
    // Faster completion (runs async background analysis)
    "omnisharp.enableAsyncCompletion": true,
    // Uses VSCode formatter settings instead of OmniSharp defaults
    "omnisharp.useEditorFormattingSettings": false,
    "typescript.updateImportsOnFileMove.enabled": "always",

    // =========================================================
    // ✨ #FORMATTERS
    // =========================================================
    "[typescriptreact]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
    },
    "[typescript]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
    "[javascript]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
    "[javascriptreact]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
    },
    "[json]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
    "[jsonc]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
    "[html]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
    "[css]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
    "[markdown]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
    "prettier.tabWidth": 4,
    "prettier.useTabs": false,
    "editor.insertSpaces": true,
    "editor.tabSize": 4,
    "dotnet.formatting.organizeImportsOnFormat": true,

    // =========================================================
    // 🌿 #SOURCE CONTROL / DIFF
    // =========================================================
    // Removes inline diff decorations in editor
    "scm.diffDecorations": "none",
    // Keeps only gutter additions indicator
    "scm.diffDecorationsGutterPattern": { "added": true },

    // =========================================================
    // 🧩 #EXTENSIONS
    // =========================================================
    "errorLens.scrollbarHackEnabled": true,
    "errorLens.onSave": true,
    "todo-tree.general.tags": ["BUG", "HACK", "FIXME", "TODO", "XXX"],
    // Solution explorer ignore folders
    "vssolution.netcoreIgnore": ["node_modules", "obj", ".ds_store", ".vs"],
    // Ignore extension recommendations popup
    "extensions.ignoreRecommendations": true,

    // =========================================================
    // 🎨 #THEME CUSTOMIZATION
    // =========================================================
    "editor.tokenColorCustomizations": {
        "[Vesper]": {
            "textMateRules": [
                {
                    "scope": ["entity.name.variable"],
                    "settings": { "foreground": "#ffffff" },
                },
                {
                    "scope": ["punctuation"],
                    "settings": { "foreground": "#a0a0a0" },
                },
                {
                    "scope": [
                        "constant.language.null",
                        "constant.language.undefined",
                    ],
                    "settings": {
                        "foreground": "#FFC799",
                        "fontStyle": "bold",
                    },
                },
            ],
        },
        "[Rosé Pine Moon (no italics)]": {
            "textMateRules": [
                {
                    "scope": ["entity.name.variable"],
                    "settings": {
                        "foreground": "#E0DEF4",
                    },
                },
                {
                    "scope": [
                        "constant.language.null",
                        "constant.language.undefined",
                    ],
                    "settings": {
                        "foreground": "#f6c177",
                        "fontStyle": "bold",
                    },
                },
            ],
        },
    },
    "workbench.colorCustomizations": {
        "[Vesper]": {
            // Tabs
            "tab.activeBorderTop": "#FFC799",
            "tab.activeModifiedBorder": "#8a8a8a",
            // Autocomplete
            "editorSuggestWidget.foreground": "#a0a0a0",
            "editorSuggestWidget.border": "#6a6a6a40",
            "editorSuggestWidget.selectedBackground": "#2b303b",
            "editorSuggestWidget.selectedForeground": "#FFC799",
            "editorSuggestWidget.highlightForeground": "#FFC799",
            // Command palette
            "quickInputList.focusForeground": "#FFC799",
            "quickInputList.focusBackground": "#2f353f",
            // Selection
            "editor.selectionBackground": "#2b303b",
            // Cursor
            "editorCursor.foreground": "#f0f0f0",
            "editorCursor.background": "#505050",
            "terminalCursor.foreground": "#f0f0f0",
            // Line numbers
            "editorLineNumber.foreground": "#3c3c3c",
            "editorLineNumber.activeForeground": "#3c3c3c",
            // Lists / selections
            "list.activeSelectionBackground": "#2b303b",
            // Bracket match (disabled visually)
            "editorBracketMatch.border": "#101010",
            "editorBracketMatch.background": "#101010",
            // Sidebar
            "sideBar.border": "#6a6a6a55",
            "editorGroup.border": "#6a6a6a55",
            // Widgets / popups
            "widget.shadow": "#00000070",
            "widget.border": "#6a6a6a40",
            // Hover
            "editorHoverWidget.background": "#353c46",
            "editorHoverWidget.border": "#3b3f48",
        },
        "[Default Dark Modern]": {
            // "editorStickyScroll.background": "#303030",
            "editorLineNumber.activeForeground": "#4a4f56",
            "editorLineNumber.foreground": "#4a4f56",
            "editorBracketMatch.border": "#1f1f1f",
            "editorBracketMatch.background": "#1f1f1f",
        },
        "[Rosé Pine Moon (no italics)]": {
            // 13121c, 191724
            "editor.background": "#191724",
            "sideBar.background": "#191724",
            "editorGutter.background": "#191724",
            "statusBar.background": "#191724",
            "welcomePage.background": "#191724",
            "activityBar.background": "#191724",
            "titleBar.activeBackground": "#191724",
            "titleBar.inactiveBackground": "#191724",
            "editorStickyScroll.background": "#26233a",
            "sideBar.border": "#393552",
            "editorGroup.border": "#393552",
            // popup backgrounds
            "editorSuggestWidget.background": "#1f1d2e",
            "editorSuggestWidget.selectedBackground": "#6e6a8633",
            "editorSuggestWidget.border": "#6e6a8680",
            "widget.shadow": "#0000005c",
            "widget.border": "#6e6a8680",
            "quickInput.background": "#1f1d2e",
            "quickInputList.focusBackground": "#6e6a8633",
            "editorActionList.background": "#1f1d2e",
            "editorActionList.focusBackground": "#6e6a8633",
            "terminal.background": "#26233a",
            "panel.background": "#26233a",
            // tab theming (compact size)
            "tab.activeBackground": "#191724",
            "tab.activeForeground": "#E0DEF4",
            // 6E6A86,9ccfd8
            "tab.activeModifiedBorder": "#9ccfd8",
            "tab.activeBorderTop": "#9ccfd8",
            // cursor
            "editorCursor.background": "#6e6a86",
            "editorCursor.foreground": "#e6edf3",
            "terminalCursor.background": "#6e6a86",
            "terminalCursor.foreground": "#e6edf3",
            // autocomplete stuff
            "list.highlightForeground": "#e0def4",
            "list.focusHighlightForeground": "#e0def4",
            "editorSuggestWidget.focusHighlightForeground": "#e0def4",
            "editorSuggestWidget.highlightForeground": "#e0def4",
            "editorLineNumber.activeForeground": "#5c5877",
            "editorLineNumber.foreground": "#5c5877",
            "editor.selectionBackground": "#3b3551",
            // matching brackets
            "editorBracketMatch.border": "#191724",
            "editorBracketMatch.background": "#191724",
        },
    },

    // =========================================================
    // 🥋 #VIM CONFIG
    // =========================================================
    "vim.leader": " ",
    // Allows * and # to work with visual selections
    "vim.visualstar": true,
    // Prevents the peek view (like Go to References) from closing when clicking outside
    // "editor.stablePeek": true,
    // Prevents Vim from recoloring status bar
    "vim.statusBarColorControl": false,
    // Keeps search matches highlighted
    "vim.hlsearch": true,
    "vim.cursorStylePerMode.normal": "block",
    "vim.cursorStylePerMode.insert": "block",
    "vim.cursorStylePerMode.visual": "block",
    "vim.cursorStylePerMode.visualblock": "block",
    "vim.cursorStylePerMode.visualline": "block",
    "vim.cursorStylePerMode.replace": "block",
    // Allows VSCode to handle Esc key (important for command palette etc.)
    "keyboard.dispatch": "keyCode",
    "vim.handleKeys": {
        "<Esc>": false,
    },
    "vim.visualModeKeyBindings": [
        // The "Greatest Remap Ever" (Paste over selection without losing your yank)
        {
            "before": ["<leader>", "p"],
            "after": ["\"", "_", "d", "P"],
        },
        // Delete to void register
        {
            "before": ["<leader>", "d"],
            "after": ["\"", "_", "d"],
        },
    ],
    "vim.normalModeKeyBindingsNonRecursive": [
        // This allows you to do <leader>d followed by a motion (like iw or ap)
        // to delete to the void register in Normal mode
        {
            "before": ["<leader>", "d"],
            "after": ["\"", "_", "d"],
        },
        {
            "before": ["<leader>", "u"],
            "commands": [
                {
                    "command": "settings.cycle.toggleFontSize",
                },
            ],
            "silent": true,
        },
        {
            // Jump to next diagnostic
            "before": ["]", "d"],
            "commands": ["editor.action.marker.nextInFiles"],
            "silent": true,
        },
        {
            // Jump to previous diagnostic
            "before": ["[", "d"],
            "commands": ["editor.action.marker.prevInFiles"],
            "silent": true,
        },
        {
            // Format document
            "before": ["<leader>", "f"],
            "commands": ["editor.action.formatDocument"],
            "silent": true,
        },
        {
            // Clear search highlight
            "before": ["<leader>", "/"],
            "commands": [":nohl"],
            "silent": true,
        },
        {
            // Toggle activity bar
            "before": ["<leader>", "t", "a"],
            "commands": ["workbench.action.toggleActivityBarVisibility"],
            "silent": true,
        },
        {
            // Toggle TODO tree panel
            "before": ["<leader>", "t", "l"],
            "commands": ["workbench.view.extension.todo-tree-container"],
            "silent": true,
        },
        {
            // Toggle minimap
            "before": ["<leader>", "t", "m"],
            "commands": ["editor.action.toggleMinimap"],
            "silent": true,
        },
        {
            // Enhanced bracket / tag jumping
            "before": ["%"],
            "commands": ["extension.matchitJumpItems"],
            "silent": true,
        },
        {
            // Open solution explorer
            "before": ["<leader>", "s", "l"],
            "commands": ["workbench.view.extension.sln_explorer"],
            "silent": true,
        },
        {
            // Center screen after half page down
            "before": ["<C-d>"],
            "after": ["<C-d>", "z", "z"],
        },
        {
            // Center screen after half page up
            "before": ["<C-u>"],
            "after": ["<C-u>", "z", "z"],
        },
        {
            // Close all tabs in current group
            "before": ["<leader>", "c", "a"],
            "commands": ["workbench.action.closeEditorsInGroup"],
            "silent": true,
        },
        {
            // Close other tabs
            "before": ["<leader>", "c", "e"],
            "commands": ["workbench.action.closeOtherEditors"],
            "silent": true,
        },
        {
            // Clear notifications
            "before": ["<leader>", "c", "n"],
            "commands": ["notifications.clearAll"],
            "silent": true,
        },
        {
            // Clear all debug breakpoints
            "before": ["<leader>", "c", "b"],
            "commands": ["workbench.debug.viewlet.action.removeAllBreakpoints"],
            "silent": true,
        },
        {
            // Quick open file search
            "before": ["<C-p>"],
            "commands": ["workbench.action.quickOpen"],
            "silent": true,
        },
        {
            "before": ["g", "r"],
            "commands": ["editor.action.goToReferences"],
            "silent": true,
        },
        {
            "before": ["K"],
            "commands": ["editor.action.showHover"],
            "silent": true,
        },
        {
            "before": ["H"],
            "commands": ["extension.vim_ctrl+pageup"],
            "silent": true,
        },
        {
            "before": ["L"],
            "commands": ["extension.vim_ctrl+pagedown"],
            "silent": true,
        },
        {
            "before": ["<leader>", "r", "n"],
            "commands": ["editor.action.rename"],
            "silent": true,
        },
        {
            "before": ["<leader>", "v", "a"],
            "after": ["G", "V", "g", "g"],
            "silent": true,
        },
        {
            "before": ["g", "s"],
            "commands": ["workbench.action.gotoSymbol"],
            "silent": true,
        },
    ],
    "vim.commandLineModeKeyBindings": [
        {
            // Fix accidental :W
            "before": ["W"],
            "after": ["w"],
        },
        {
            // Fix accidental :Q
            "before": ["Q"],
            "after": ["q"],
        },
    ],
    "workbench.editor.empty.hint": "hidden",
    "workbench.activityBar.location": "hidden",
    "editor.minimap.enabled": false,
    "terminal.integrated.initialHint": false,
    "workbench.colorTheme": "Vesper",
}
